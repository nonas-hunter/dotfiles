(defwindow bar
           :monitor 0
           :geometry (geometry :x "0%"
                               :y "20px"
                               :width "90%"
                               :height "20px"
                               :anchor "top center")
           :stacking "overlay"
           :exclusive "true"
  	   (time))

(defwidget time []
  (centerbox :orientation "h"
    (time)))

(defpoll time :interval "10s"
  "date '+%H:%M %b %d, %Y'")
